Options -Indexes

RewriteEngine On

# Канонический HTTPS и единый хост
RewriteCond %{HTTP_HOST} ^www\.protect-online\.ru$ [NC]
RewriteRule ^ https://protect-online.ru%{REQUEST_URI} [R=301,L]

RewriteCond %{HTTP_HOST} ^(www\.)?protect-online\.ru$ [NC]
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://protect-online.ru%{REQUEST_URI} [R=301,L]

# Редирект со старого имени
RewriteRule ^index3\.html$ / [R=301,L]

# Технические редиректы
Redirect 301 /bot https://t.me/protect_3573643763_bot
Redirect 301 /go https://t.me/ProBankro
Redirect 301 /me https://t.me/IgStankevich

# Запрет служебных и конфигурационных файлов
RewriteRule (^|/)\.(?!well-known/) - [F,L]
RewriteRule ^storage/ - [F,L,NC]
RewriteRule ^(?:config\.local\.php|submit-lead\.php|test-email\.php|email-debug\.log|leads\.log)$ - [F,L,NC]
RewriteRule \.(?:log|ini|bak|dist|sql)$ - [F,L,NC]

<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"
    Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; frame-src 'self' https://yandex.ru https://*.yandex.ru; object-src 'none'; script-src 'self' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; connect-src 'self'; upgrade-insecure-requests"
    <FilesMatch "\.(php|html)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
    </FilesMatch>

    <FilesMatch "\.(css|js|jpg|jpeg|png|gif|svg|ico|woff|woff2)$">
        Header set Cache-Control "public, max-age=604800, immutable"
    </FilesMatch>
</IfModule>
